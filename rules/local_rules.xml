<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<!-- Suppress common Docker healthcheck exec_start events -->
<group name="docker,">
  <rule id="100200" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /bin/sh -c pg_isready</match>
    <description>Suppress Docker healthcheck: pg_isready (postgres)</description>
  </rule>

  <rule id="100201" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: pg_isready</match>
    <description>Suppress Docker healthcheck: pg_isready (postgres)</description>
  </rule>

  <rule id="100202" level="0">
    <if_sid>87907</if_sid>
    <regex>exec_start:\.*curl\.*health</regex>
    <description>Suppress Docker healthcheck: curl to health endpoint</description>
  </rule>

  <rule id="100203" level="0">
    <if_sid>87907</if_sid>
    <regex>exec_start:\.*wget\.*health</regex>
    <description>Suppress Docker healthcheck: wget to health endpoint</description>
  </rule>

  <rule id="100204" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /watchtower --health-check</match>
    <description>Suppress Docker healthcheck: watchtower</description>
  </rule>

  <rule id="100205" level="0">
    <if_sid>87907</if_sid>
    <match>healthcheck</match>
    <description>Suppress Docker healthcheck: healthcheck</description>
  </rule>
  <rule id="100206" level="0">
    <if_sid>87907</if_sid>
    <regex>exec_start:\.*curl --fail \.*localhost\.* \|\| exit 1</regex>
    <description>Suppress Docker healthcheck: curl localhost fail</description>
  </rule>
  <rule id="100207" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /bin/sh -c redis-cli ping</match>
    <description>Suppress Docker healthcheck: redis</description>
  </rule>
  <rule id="100208" level="0">
    <if_sid>87907</if_sid>
    <regex>exec_start:\.*curl\.*ping</regex>
    <description>Suppress Docker healthcheck: arr ping</description>
  </rule>
  <rule id="100209" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: wget --no-verbose --tries=1 -O - http://localhost:7745/api/v1/status</match>
    <description>Suppress Docker healthcheck: homebox</description>
  </rule>
  <rule id="100210" level="0">
    <if_sid>87907</if_sid>
    <match>xec_start: /bin/sh -c pgrep -f main.py</match>
    <description>Suppress Docker healthcheck: decluttarr</description>
  </rule>
  <rule id="100211" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /bin/sh -c node src/scripts/health-check.js</match>
    <description>Suppress Docker healthcheck: ynab</description>
  </rule>
  <rule id="100212" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: curl -fs -S -L --max-time 2 http://localhost:8000</match>
    <description>Suppress Docker healthcheck: paperless</description>
  </rule>
  <rule id="100213" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /bin/sh -c netstat -a | grep -q 9999</match>
    <description>Suppress Docker healthcheck: stash</description>
  </rule>
  <rule id="100214" level="0">
    <if_sid>87907</if_sid>
    <match>exec_start: /bin/sh -c /usr/bin/timeout 5s /bin/sh -c "/usr/bin/wg show | /bin/grep -q interface || exit 1"</match>
    <description>Suppress Docker healthcheck: wg-easy</description>
  </rule>
  <rule id="100215" level="0">
    <if_sid>87907</if_sid>
    <regex>exec_start:\.*curl --fail \.*http://localhost\.*status"$</regex>
    <description>Suppress Docker healthcheck: curl localhost fail</description>
  </rule>

</group>


<!-- Added REH 2025-06-24 -->
<!-- Authentik failures -->

<group name="authentik,">
  <rule id="100008" level="5">
    <program_name>docker/authentik_server</program_name>
    <match>login_failed</match>
    <user negate="yes">AnonymousUser</user>
    <description>Failed Authentik Login</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>
  <rule id="100009" level="9">
    <program_name>docker/authentik_server</program_name>
    <match>login_failed</match>
    <user>AnonymousUser</user>
    <description>Invalid Authentik Login: No such user</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
    <mitre>
      <id>T1589.001</id>
    </mitre>
  </rule>
</group>

<group name="synology,">
  <rule id="100020" level="5">
    <hostname>Synology</hostname>
    <extra_data>Test message</extra_data>
    <description>Diagnostic Syslog Test</description>
    <group>syscheck,</group>
    <mitre>
      <id>T1590.006</id>
    </mitre>
  </rule>
  <rule id="100021" level="5">
    <hostname>Synology</hostname>
    <extra_data>failed to sign in</extra_data>
    <description>Failed Synology Login</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>
</group>

<group name="autocolor, malware,">

 <!-- Post malware execution -->
  <rule id="100401" level="12" frequency="2" ignore="120">
    <if_sid>200155</if_sid>
    <field name="eventdata.Image" type="pcre2">(?i).elf</field>
    <field name="eventdata.targetFilename" type="pcre2">\/var\/log\/cross\/auto-color</field>
    <description>Auto-color malware duplicates itself as $(eventdata.targetFilename).</description>
    <mitre>
      <id>T1036.005</id>
      <id>T1059</id>
    </mitre>
  </rule>


  <rule id="100402" level="12" frequency="2" ignore="120">
    <if_sid>200155</if_sid>
    <field name="eventdata.Image" type="pcre2">(?i).elf</field>
    <field name="eventdata.targetFilename" type="pcre2">\/usr\/lib\/[^\/]+\/libcext\.so\.2</field>
    <description>Auto-color malware created file $(eventdata.TargetFilename) to enable malicious library hooking of libc functions.</description>
    <mitre>
      <id>T1574.006</id>
      <id>T1036.005</id>
    </mitre>
  </rule>


  <rule id="100403" level="12" frequency="2" ignore="120">
    <if_sid>200155</if_sid>
    <field name="eventdata.Image" type="pcre2">(?i).elf</field>
    <field name="eventdata.targetFilename" type="pcre2">\/etc\/ld\.so\.preload</field>
    <description>Auto-color malware created file $(eventdata.targetFilename) to load a malicious library for persistence and libc function hooking.</description>
    <mitre>
      <id>T1574.006</id>
      <id>T1546.015</id>
      <id>T1098</id>
    </mitre>
  </rule>

    <!-- Rule for File Deletion (Event ID 23)-->
  <rule id="100404" level="12" frequency="2" ignore="120">
    <if_sid>200157</if_sid>
    <field name="eventdata.Image" type="pcre2">(?i).elf</field>
    <field name="eventdata.targetFilename" type="pcre2">(?i).elf</field>
    <description>Possible Auto-color malware behavior: deletes its original $(eventdata.targetFilename).</description>
    <mitre>
      <id>T1070.004</id>
    </mitre>
  </rule>

  <!-- Rule for File Creation /var/log/cross/config-err-* -->
  <rule id="100405" level="12" frequency="2" ignore="120">
    <if_sid>200155</if_sid>
    <field name="eventdata.Image" type="pcre2">(?i).elf</field>
    <field name="eventdata.targetFilename" type="pcre2">\/var\/log\/cross\/(?:.*\/)?config-err-.+</field>
    <description>Auto-color malware created file $(eventdata.targetFilename) to facilitate enecrypted C2 communication.</description>
    <mitre>
      <id>T1071.001</id>
      <id>T1008</id>
      <id>T1568</id>
    </mitre>
  </rule>

</group>
